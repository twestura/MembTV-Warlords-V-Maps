
#HEADER_START
/*
 * Pacific Islands for Warlords V, edited by T-West March 2026.
 *
 * The main feature of this version is to remove the small dockable ponds in the
 * backs of player bases to prevent isolated Fish Trap booming. We place a land
 * in an unused corner of the map and place naval placeholders using the land's
 * id. These placeholders fill the map with all water terrain that is connected
 * to the outside, isolating the back ponds. Modified buildings then replace the
 * terrain of the back ponds to the shoreless 2d water, which is undockable.
 */

/* Based on: */
/* Pacific Islands - 2023 */
#HEADER_END

#MKCONSTS

#include_drs random_map.def

#include_drs EnlargeMap.inc

#const PHON 1543
#const PHONA 1545 /* Land and beaches. */
#const PHONN 1546 /* Beaches, Shallows, and Water. */
#const BUILDING 199
#const DEAD_BUILDING 278

/* Hack to make dead fish traps remove trapped ponds. */
effect_percent GAIA_SET_ATTRIBUTE BUILDING ATTR_RADIUS_1 50
effect_percent GAIA_SET_ATTRIBUTE BUILDING ATTR_RADIUS_2 50
/* Water prevents pond docks (this was the prettiest undockable water). */
effect_amount GAIA_SET_ATTRIBUTE BUILDING ATTR_FOUNDATION_TERRAIN 15
/* Same terrain restriction as the naval placeholder. */
effect_amount GAIA_SET_ATTRIBUTE BUILDING ATTR_TERRAIN_ID 19
effect_amount GAIA_SET_ATTRIBUTE BUILDING ATTR_HITPOINTS 0
effect_amount GAIA_SET_ATTRIBUTE DEAD_BUILDING ATTR_STORAGE_VALUE 0

<PLAYER_SETUP>

#SETPHATTR

if  2_PLAYER_GAME
	if TINY_MAP
    #define PACIFIC_SET_ISLANDS
    behavior_version 1
	else
	endif
else
endif

if LUDIKRIS_MAP
  #define PACIFICEXTRASPACE
endif

if PACIFIC_SET_ISLANDS
  direct_placement
else
  random_placement
endif

ai_info_map_type MIGRATION 0 0 0
#include_drs thebr_setup.inc

<LAND_GENERATION>
base_terrain DLC_WATER5

#const SPECIALJUNGLELEAVES 77

