<ELEVATION_GENERATION>
#const LAYER_L 60
create_elevation 1 {
  enable_balanced_elevation
  base_terrain LAYER_L
	if TINY_MAP
    number_of_clumps 5
    number_of_tiles 500
	elseif SMALL_MAP
    number_of_clumps 7
    number_of_tiles 720
	elseif MEDIUM_MAP
    number_of_clumps 10
    number_of_tiles 1000
	elseif LARGE_MAP
    number_of_clumps 14
    number_of_tiles 1400
	elseif HUGE_MAP
    number_of_clumps 16
    number_of_tiles 1600
	elseif GIGANTIC_MAP
    number_of_clumps 20
    number_of_tiles 2000
	else
    number_of_clumps 80
    number_of_tiles 8000
	endif
}

<TERRAIN_GENERATION>

create_terrain DLC_MANGROVESHALLOW
{
base_terrain DLC_WATER5
if HUGE_MAP
land_percent 15
elseif GIGANTIC_MAP
land_percent 15
elseif LUDIKRIS_MAP
land_percent 15
else

	if PACIFIC_WFORESTREDUCTION1

land_percent 14

	elseif PACIFIC_WFORESTREDUCTION2

land_percent 15

	else

land_percent 16

	endif



endif

if HUGE_MAP
number_of_clumps 68
elseif GIGANTIC_MAP
number_of_clumps 68
elseif LUDIKRIS_MAP
number_of_clumps 68
else

	if PACIFIC_WFORESTREDUCTION1

number_of_clumps 45

	elseif PACIFIC_WFORESTREDUCTION2

number_of_clumps 45

	else

number_of_clumps 45

	endif


endif

	if PACIFIC_WFORESTREDUCTION1

spacing_to_other_terrain_types 5

	elseif PACIFIC_WFORESTREDUCTION2

spacing_to_other_terrain_types 6

	else

spacing_to_other_terrain_types 6

	endif

set_avoid_player_start_areas
}

create_terrain DLC_MANGROVEFOREST
{
base_terrain DLC_MANGROVESHALLOW
land_percent 100
spacing_to_other_terrain_types 3
number_of_clumps 1000
set_avoid_player_start_areas
}

create_terrain DLC_MANGROVEFOREST
{
base_terrain DLC_MANGROVESHALLOW
land_percent 100
spacing_to_other_terrain_types 3
number_of_clumps 1000
set_avoid_player_start_areas
}

create_terrain DLC_MANGROVEFOREST
{
base_terrain DLC_MANGROVESHALLOW
if TINY_MAP
number_of_tiles 200
else
number_of_tiles 400
endif
spacing_to_other_terrain_types 2
number_of_clumps 1000
set_avoid_player_start_areas
}


