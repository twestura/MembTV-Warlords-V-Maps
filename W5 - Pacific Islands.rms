  number_of_objects 99999
  place_on_specific_land_id 90
  actor_area outside_water
  actor_area_radius 0
}

/* Fill in the back ponds. */
create_object BUILDING {
  number_of_objects 99999
  actor_area_to_place_in back_pond
  /* Ensure only ponds disconnected from the outside water are selected. */
  avoid_actor_area outside_water
  /* Avoid filling in bubbles created by middle island border fuzziness. */
  avoid_actor_area mid_island_3
}

