/* Central Islands */
if PACIFIC_FLIPCENTRALISLANDS
  /* North Central Island */
  create_land {
    terrain_type DLC_JUNGLEGRASS
    land_percent 40
    land_position 35 65
    base_size 8
    border_fuzziness 5
    clumping_factor 30

    if PACIFIC_WFORESTREDUCTION1
      bottom_border 20
      left_border 20
    elseif PACIFIC_WFORESTREDUCTION2
      bottom_border 19
      left_border 19
    else
      bottom_border 16
      left_border 16
    endif

    top_border 38
    right_border 38
    zone 60
    other_zone_avoidance_distance 6

    land_id 10
  }

