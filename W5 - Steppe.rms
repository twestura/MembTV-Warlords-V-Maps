		#const STONE_TERTIARY_DISTANCE 12
		#define STONE_TERTIARY

		#include_drs includes/starting_resources.inc

		if DEATH_MATCH
		elseif INFINITE_RESOURCES
		else
			#define HERDABLE_STARTING_COUNT_FOUR

			#include_drs includes/herdable_starting.inc
			#include_drs includes/herdable.inc
			#include_drs includes/huntable.inc
			#include_drs includes/lureable.inc
			#include_drs includes/furbearers.inc
		endif

		if INFINITE_RESOURCES
		else
			create_object FORAGE_BUSH
			{
				second_object PLANT_DEAD
				number_of_objects 4
				number_of_groups 1024
				set_tight_grouping
				group_placement_radius 1
				min_distance_to_players 26
				set_circular_placement
				enable_tile_shuffling
				temp_min_distance_group_placement 14
				terrain_to_place_on MIDDLE_TERRAIN

				min_distance_group_placement 1
				max_distance_to_other_zones 8
				avoid_forest_zone 2
