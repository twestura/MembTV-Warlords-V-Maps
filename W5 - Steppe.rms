	#const CONFINED_INCREASE 1.2
else
	#const CONFINED_INCREASE 1
endif


/* Ensure that Oystering Ships can attack. */
effect_amount SET_ATTRIBUTE OYSTERING_SHIP ATTR_GARRISON_FIREPOWER -1

<LAND_GENERATION>
	base_terrain BASE_TERRAIN

	create_land {
		terrain_type MIDDLE_TERRAIN
		land_percent 100
		top_border 24
		bottom_border 24
		left_border 24
		right_border 24

		if MAPSIZE_ABOVE_SMALL
			border_fuzziness 10
		elseif MAPSIZE_ABOVE_MEDIUM
			border_fuzziness 8
		elseif MAPSIZE_ABOVE_NORMAL
			border_fuzziness 6
		else
			border_fuzziness 12
		endif

		land_position 50 50
		land_id 420
	}

	create_player_lands {
		terrain_type SPAWN_TERRAIN
		number_of_tiles 768
		base_size 10
		clumping_factor 15
		top_border 8
		left_border 8
		right_border 8
		bottom_border 8
		other_zone_avoidance_distance 2

		if MAPSIZE_ABOVE_INCREDIBLE
			circle_radius 29 2
		elseif MAPSIZE_ABOVE_GIANT
			circle_radius 30 2
		elseif MAPSIZE_ABOVE_MEDIUM
			circle_radius 31 2
		elseif MAPSIZE_ABOVE_TINY
			circle_radius 32 2
		else
			circle_radius 33 2
		endif
	}

<ELEVATION_GENERATION>
	create_elevation 5
	{
		enable_balanced_elevation
		base_terrain BASE_TERRAIN

		number_of_tiles (512 * MAPSCALE_AREA)
		number_of_clumps (24 * MAPSCALE_AREA)
	}

	create_elevation 1
	{
		enable_balanced_elevation
		base_terrain MIDDLE_TERRAIN

		number_of_tiles (64 * MAPSCALE_AREA)
		number_of_clumps (12 * MAPSCALE_AREA)
	}

