<CONNECTION_GENERATION>
	create_connect_all_players_land
	{
		replace_terrain WATER_SHALLOW SHALLOWS
		replace_terrain WATER_MEDIUM SHALLOWS
		replace_terrain WATER_DEEP SHALLOWS

		terrain_cost BASE_TERRAIN 1
		terrain_cost WATER_SHALLOW 2
		terrain_cost WATER_MEDIUM 3
		terrain_cost WATER_DEEP 4

		terrain_size WATER_SHALLOW 1 0
		terrain_size WATER_MEDIUM 1 0
		terrain_size WATER_DEEP 1 0
	}

<OBJECTS_GENERATION>
	if TERRAIN_DEBUGGING
	else
		#define PRELIMINARIES
		if PRELIMINARIES
			#const RESOURCE_SPACING_DEFAULT 10
			#const RESOURCE_SPACING_FAR 16
			#const RESOURCE_RESTRICTION 2

			#include_drs includes/object_setup.inc
			#include_drs includes/market_objects.inc

			create_object PLACEHOLDER_GENERIC
			{
				number_of_objects 1024
				temp_min_distance_group_placement 2
				terrain_to_place_on MIDDLE_TERRAIN

				actor_area 7000
				actor_area_radius 8
			}
		endif

		#const ADDITIONAL_VILLAGERS 3
		#const VILLAGER_SPACING 4

		if REGICIDE
			#const VILLAGER_DISTANCE 4
		elseif CAPTURE_THE_RELIC
			#const VILLAGER_DISTANCE 4
		else
			#const VILLAGER_DISTANCE 0
		endif

		#include_drs includes/town_centres.inc
		#include_drs includes/villagers.inc
		#include_drs includes/scouts.inc
		#include_drs includes/walls.inc

		#include_drs includes/defend_wonder.inc
		#include_drs includes/regicide.inc
		#include_drs includes/capture_relic.inc

		start_random
			percent_chance 25 #define YURT_ABC
			percent_chance 25 #define YURT_ABD
			percent_chance 25 #define YURT_ACD
			percent_chance 25 #define YURT_BCD
		end_random

		if YURT_ABC
			create_object YURT_LEATHER_A
		elseif YURT_ABD
			create_object YURT_LEATHER_A
		elseif YURT_ACD
			create_object YURT_LEATHER_A
		elseif YURT_BCD
			create_object YURT_LEATHER_B
		endif
		{
			set_place_for_every_player
			min_distance_to_players 8
			set_circular_placement
			find_closest
			enable_tile_shuffling
			terrain_to_place_on MIDDLE_TERRAIN

			max_distance_to_other_zones 4
			avoid_forest_zone 2
			avoid_cliff_zone 2
			min_distance_to_map_edge 2

			actor_area 40
			actor_area_radius 4

			avoid_actor_area 40 /* Yurt */
		}

		if YURT_ABC
			create_object YURT_LEATHER_B
		elseif YURT_ABD
			create_object YURT_LEATHER_B
		elseif YURT_ACD
			create_object YURT_LEATHER_C
		elseif YURT_BCD
			create_object YURT_LEATHER_C
		endif
		{
			set_place_for_every_player
			min_distance_to_players 8
			set_circular_placement
			find_closest
			enable_tile_shuffling
			terrain_to_place_on MIDDLE_TERRAIN

			max_distance_to_other_zones 4
			avoid_forest_zone 2
			avoid_cliff_zone 2
			min_distance_to_map_edge 2

			actor_area 40
			actor_area_radius 4

			avoid_actor_area 40 /* Yurt */
		}

		if YURT_ABC
			create_object YURT_LEATHER_C
		elseif YURT_ABD
			create_object YURT_LEATHER_BIG
		elseif YURT_ACD
			create_object YURT_LEATHER_BIG
		elseif YURT_BCD
			create_object YURT_LEATHER_BIG
		endif
		{
			set_place_for_every_player
			min_distance_to_players 8
			set_circular_placement
			find_closest
			enable_tile_shuffling
			terrain_to_place_on MIDDLE_TERRAIN

			max_distance_to_other_zones 4
			avoid_forest_zone 2
			avoid_cliff_zone 2
			min_distance_to_map_edge 2

			actor_area 40
			actor_area_radius 4

			avoid_actor_area 40 /* Yurt */
		}

		create_object STRAGGLER_SPAWN
		{
			set_place_for_every_player
			set_gaia_object_only
			number_of_objects 8
			min_distance_to_players 0
			max_distance_to_players 14
			set_circular_placement
			enable_tile_shuffling
			temp_min_distance_group_placement 4

			max_distance_to_other_zones 2
			avoid_forest_zone 2
			avoid_cliff_zone 2

			actor_area 60
			actor_area_radius 3

			avoid_actor_area 10 /* Town Centres */
			avoid_actor_area 20 /* Villagers */
			avoid_actor_area 21 /* Villagers, Additional A */
			avoid_actor_area 22 /* Villagers, Additional B */
			avoid_actor_area 30 /* Scout */
			avoid_actor_area 31 /* Scout, Secondary */
			avoid_actor_area 32 /* Scout, Tertiary */
			avoid_actor_area 50 /* Walls */
			avoid_actor_area 51 /* Walls, Second Layer */
			avoid_actor_area 52 /* Walls, Third Layer */
			avoid_actor_area 60 /* Straggler, Spawn */
			avoid_actor_area 61 /* Straggler, Escalation Mode */

			avoid_actor_area 5100 /* King */
		}

		#const FORAGE_BUSH_PRIMARY_DISTANCE 4
		#define FORAGE_BUSH_PRIMARY

		#const GOLD_PRIMARY_DISTANCE 8
		#const GOLD_PRIMARY_SIZE 5
		#define GOLD_PRIMARY

		#const GOLD_SECONDARY_DISTANCE 8
