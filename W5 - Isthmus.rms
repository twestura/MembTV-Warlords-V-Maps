/* Oystering Ship constant for the Dock arrow bug fix. */
#const OYSTERING_SHIP 2171

<PLAYER_SETUP>
	#include_drs includes/preliminaries.inc
	#include_drs includes/gaia_civilisation.inc

	#define WATER_OCEAN
	#include_drs includes/water_preset.inc
	water_definition WATER_PRESET

	random_placement
	ai_info_map_type SCANDINAVIA 0 0

	#const NEW_PYRAMID 1562
	effect_percent GAIA_SET_ATTRIBUTE NEW_PYRAMID ATTR_RADIUS_1 250
	effect_percent GAIA_SET_ATTRIBUTE NEW_PYRAMID ATTR_RADIUS_2 250
	effect_amount GAIA_SET_ATTRIBUTE NEW_PYRAMID ATTR_STANDING_GRAPHIC 4121

	if CONFINED_SETUP
		#const CONFINED_INCREASE 1.2
	else
		#const CONFINED_INCREASE 1
	endif
	

/* Ensure that Oystering Ships can attack. */
effect_amount SET_ATTRIBUTE OYSTERING_SHIP ATTR_GARRISON_FIREPOWER -1

<LAND_GENERATION>
	base_terrain RESTRICTION_TERRAIN

	create_land
	{
		terrain_type MIDDLE_TERRAIN
		number_of_tiles 1024
		base_size 12
		base_elevation 1
		land_position 50 50
		other_zone_avoidance_distance 7
		zone 1
		land_id 420
	}

	create_player_lands
	{
		terrain_type SPAWN_TERRAIN
		land_percent 100
		base_size 8
		clumping_factor 15
		other_zone_avoidance_distance 7
		base_elevation 1
		zone 1
	}

	create_player_lands
	{
		terrain_type BEACH_TERRAIN
		land_percent 100
		base_size 8
		clumping_factor 15
		other_zone_avoidance_distance 7
		zone 2
		land_id 500

		if MAPSIZE_MINI
			circle_radius 33 0
		elseif MAPSIZE_TINY
			circle_radius 34 1
		elseif MAPSIZE_SMALL
			circle_radius 34 1
		elseif MAPSIZE_MEDIUM
			circle_radius 35 2
		elseif MAPSIZE_NORMAL
			circle_radius 36 3
		elseif MAPSIZE_LARGE
			circle_radius 37 4
		elseif MAPSIZE_HUGE
			circle_radius 38 5
		elseif MAPSIZE_GIANT
			circle_radius 39 6
		elseif MAPSIZE_MASSIVE
			circle_radius 39 6
		elseif MAPSIZE_ENORMOUS
			circle_radius 39 6
		elseif MAPSIZE_COLOSSAL
			circle_radius 39 6
		elseif MAPSIZE_INCREDIBLE
			circle_radius 39 6
		elseif MAPSIZE_MONSTROUS
			circle_radius 40 6
		elseif MAPSIZE_LUDICROUS
			circle_radius 40 6
		endif
	}

<ELEVATION_GENERATION>
	create_elevation 5
	{
		enable_balanced_elevation
		base_terrain BASE_TERRAIN

		number_of_tiles (256 * MAPSCALE_AREA)
		number_of_clumps (48 * MAPSCALE_AREA)
	}

