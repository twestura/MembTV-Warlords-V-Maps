}

/*
 * These macros rely only on the actor areas and do not require
 * `generate_for_first_land_only`.
 */
#TCBOXES
#VISION

/*
 * The Villagers rely on the player lands and need
 * `generate_for_first_land_only`.
 */
create_object PHON {
  set_place_for_every_player
  generate_for_first_land_only
  number_of_objects 5
  min_distance_to_players 1
  max_distance_to_players 1
  find_closest
  actor_area near_positioner
  actor_area_radius 0
}

create_object PHOFF {
  set_place_for_every_player
  generate_for_first_land_only
  min_distance_to_players 1
  max_distance_to_players 1
  find_closest
  second_object HERDABLE_A
  actor_area herd0
  actor_area_radius 0
  avoid_actor_area near_positioner
}

create_object PHON {
  set_place_for_every_player
  generate_for_first_land_only
  actor_area_to_place_in herd0
  actor_area herd1
  actor_area_radius 1
}

create_object PHON {
  set_place_for_every_player
  generate_for_first_land_only
  max_distance_to_players 0
  actor_area tc_d1
  actor_area_radius 1
}

create_object PHON {
