endif

<OBJECTS_GENERATION>
create_object TOWN_CENTER {
  set_place_for_every_player
  max_distance_to_players 0
  actor_area 1
  actor_area_radius 10
  generate_for_first_land_only
}

/* Creates the "2x2 center" of the Town Center. */
create_object PHON {
  set_place_for_every_player
  max_distance_to_players 0
  actor_area tc_d
  actor_area_radius 0
  generate_for_first_land_only
}

create_object PHON {
  number_of_objects 2
  set_place_for_every_player
  find_closest
