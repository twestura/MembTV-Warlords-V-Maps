#const HERDABLE_A DLC_GOAT
#const STRAGGLER SNOWPINETREE

#MKCONSTS

#const ICENAV 26
#const TERRAIN_BLOCKER 1613
#const GATE1 64
#const GATE2 88
#const CITY_GATE1 1579
#const CITY_GATE2 1583
#const CITY_GATE1_DEAD 1510
#const CITY_GATE2_DEAD 1511
#const BENCH 2524
#const ON_GRID 278
#const TEMP 278
#const SNOW_ROAD 38
#const SNOWSTRONG 74
#const SNOWLIGHT 73
#const GRAVEL 70
#const MUD 76
#const ROCK2 1323
