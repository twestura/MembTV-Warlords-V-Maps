<PLAYER_SETUP>
behavior_version 1
random_placement

#SETPHATTR

effect_amount SET_ATTRIBUTE WALL_CLASS ATTR_TERRAIN_ID 4
effect_amount SET_ATTRIBUTE GATE_CLASS ATTR_TERRAIN_ID 4
effect_amount SET_ATTRIBUTE CITY_GATE1 ATTR_TERRAIN_ID 0
effect_amount SET_ATTRIBUTE CITY_GATE2 ATTR_TERRAIN_ID 0
/* effect_amount SET_ATTRIBUTE TERRAIN_BLOCKER ATTR_TERRAIN_ID 0 */
effect_amount SET_ATTRIBUTE CITY_GATE1 ATTR_HITPOINTS 0
effect_amount SET_ATTRIBUTE CITY_GATE2 ATTR_HITPOINTS 0
effect_amount SET_ATTRIBUTE CITY_GATE1_DEAD ATTR_STORAGE_VALUE 0
effect_amount SET_ATTRIBUTE CITY_GATE2_DEAD ATTR_STORAGE_VALUE 0

effect_amount SET_ATTRIBUTE ROCK2 ATTR_OCCLUSION_MODE 2

/* Larger LoS for the temporary vision to fill the starting base. */
effect_amount SET_ATTRIBUTE TEMPORARY_REVEALER ATTR_LINE_OF_SIGHT 20

<LAND_GENERATION>
base_terrain GRASS

create_player_lands {
	terrain_type GRASS2
	base_size 12
	land_percent 5
	top_border 10
	bottom_border 10
	right_border 10
	left_border 10
	if 2_PLAYER_GAME
		circle_radius 35 0
	else
		circle_radius 36 0
	endif
	/* set_zone_by_team */
}

create_player_lands {
	terrain_type GRASS3
	base_size 12
	number_of_tiles 150
	/* set_zone_by_team */
}

create_land {
	terrain_type SNOW
	base_size 4
	land_position 50 50
	land_percent 100
	clumping_factor 40
	if TINY_MAP
  	top_border 30
  	bottom_border 30
  	right_border 30
  	left_border 30
	else
  	top_border 27
  	bottom_border 27
  	right_border 27
  	left_border 27
	endif
	land_id 666
}

<ELEVATION_GENERATION>
create_elevation 4 {
	base_terrain SNOW
	if 2_PLAYER_GAME
  	number_of_tiles 555555
  	number_of_clumps 5
  	spacing 4
	else
  	number_of_tiles 555555
  	number_of_clumps 10
  	spacing 10
	endif
	set_scale_by_groups
	enable_balanced_elevation
}

create_elevation 1 {
  base_terrain GRASS
  number_of_tiles 200
  number_of_clumps 15
  set_scale_by_size
  enable_balanced_elevation
}

