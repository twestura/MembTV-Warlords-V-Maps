#HEADER_END
/*
 * Defeat players if the game mode is not set to random map.
 * Includes a check for the secondary game mode checkboxes.
 */
if ANTIQUITY_MODE
  #define ADMIN_RESTART
elseif RANDOM_MAP
  if REGICIDE
    #define ADMIN_RESTART
  elseif EMPIRE_WARS
    #define ADMIN_RESTART
  elseif SUDDEN_DEATH
    #define ADMIN_RESTART
  endif
else
  #define ADMIN_RESTART
endif
if TINY_MAP
else
  #define ADMIN_RESTART
endif
if DEFAULT_RESOURCES
else
  #define ADMIN_RESTART
endif
if DARK_AGE_START
else
  #define ADMIN_RESTART
endif
if TURBO_MODE
  #define ADMIN_RESTART
endif
if ADMIN_RESTART
  <PLAYER_SETUP>
  guard_state SABOTEUR AMOUNT_GOLD 0 1
endif



#const HERDABLE_A DLC_GOAT
#const STRAGGLER SNOWPINETREE

#MKCONSTS

#const ICENAV 26
#const TERRAIN_BLOCKER 1613
#const GATE1 64
#const GATE2 88
#const CITY_GATE1 1579
#const CITY_GATE2 1583
#const CITY_GATE1_DEAD 1510
#const CITY_GATE2_DEAD 1511
#const BENCH 2524
#const ON_GRID 278
#const TEMP 278
#const SNOW_ROAD 38
#const SNOWSTRONG 74
#const SNOWLIGHT 73
#const GRAVEL 70
#const MUD 76
#const ROCK2 1323
#const REVEAL2_TEMP 1873
#const MAPLELEAVES 2031
#const PH_GENERIC_OFF 649


/* Oystering Ship constant for the Dock arrow bug fix. */
#const OYSTERING_SHIP 2171

<PLAYER_SETUP>
behavior_version 2
random_placement

#SETPHATTR

/* Outlines behind rocks. */
effect_amount SET_ATTRIBUTE ROCK2 ATTR_OCCLUSION_MODE 2

/* Slightly increase the LoS for the Stone Revealer. */
effect_amount SET_ATTRIBUTE REVEAL2_TEMP ATTR_LINE_OF_SIGHT 12


/* Ensure that Oystering Ships can attack. */
effect_amount SET_ATTRIBUTE OYSTERING_SHIP ATTR_GARRISON_FIREPOWER -1

<LAND_GENERATION>
base_terrain GRASS
enable_waves 0

/* Central Hill */
create_land {
	terrain_type SNOW
	base_size 4
	land_position 50 50
	if TINY_MAP
  	top_border 30
  	bottom_border 30
  	right_border 30
  	left_border 30
	else
  	top_border 27
  	bottom_border 27
  	right_border 27
  	left_border 27
	endif
	land_id 666
	border_fuzziness 100
}

/* Secondary Base */
create_player_lands {
	terrain_type GRASS2
	number_of_tiles 0
	if 2_PLAYER_GAME
  	base_size 14
	else
  	base_size 14
	endif
	if 2_PLAYER_GAME
		circle_radius 34 0
	else
		circle_radius 37 0
	endif
}

/* Primary Base */
create_player_lands {
	terrain_type GRASS3
	base_size 12
	number_of_tiles 0
}

<ELEVATION_GENERATION>
/* Elevation for the main hill. */
#REPEAT(8)
  create_elevation 4 {
  	base_terrain SNOW
  	enable_balanced_elevation
  	if 2_PLAYER_GAME
   	number_of_tiles 555555
   	number_of_clumps 8192
   	spacing 4
  	else
   	number_of_tiles 555555
   	number_of_clumps 8192
   	spacing 10
  	endif
  }
#END_REPEAT

/* Small hills around the map. */
create_elevation 1 {
	base_terrain GRASS
	number_of_tiles 200
	number_of_clumps 15
	set_scale_by_size
	enable_balanced_elevation
}

<TERRAIN_GENERATION>
/* Outer terrain masking. */
create_terrain SNOWSTRONG {
	base_terrain GRASS
	land_percent 10
	number_of_clumps 15
	set_avoid_player_start_areas 25
	terrain_mask 1
	set_scale_by_size
}

create_terrain GRASS_FLOWERS_1 {
	base_terrain GRASS
	land_percent 3
	number_of_clumps 10
	set_scale_by_size
	set_avoid_player_start_areas 20
}

#REPEAT(8)
  create_terrain MUD {
  	base_terrain GRASS_FLOWERS_1
  	land_percent 100
  	number_of_clumps 8192
  	terrain_mask 1
  }
#END_REPEAT

create_terrain GRASS_FLOWERS_2 {
	base_terrain GRASS
	land_percent 3
	number_of_clumps 10
	terrain_mask 1
	set_scale_by_size
}

/* Walls and Gates terrain for the second base. */
#REPEAT(8)
  create_terrain ICYSHORE  {
  	base_terrain GRASS3
  	land_percent 100
  	number_of_clumps 8192
  }
#END_REPEAT

#REPEAT(8)
  create_terrain GRASS3  {
  	base_terrain ICYSHORE
  	land_percent 100
  	number_of_clumps 8192
  	spacing_to_other_terrain_types 3
  }
#END_REPEAT

#REPEAT(8)
  create_terrain ICE {
    base_terrain ICYSHORE
    land_percent 100
    number_of_clumps 8192
    spacing_to_other_terrain_types 1
  }
#END_REPEAT

/*
 * Populate the second base with a one tile woodline that surrounds Stone and
 * more forest.
 */
#REPEAT(8)
  create_terrain LEAVES {
    base_terrain GRASS3
    land_percent 100
    number_of_clumps 8192
    spacing_to_other_terrain_types 6
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DIRT2 {
    base_terrain GRASS3
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

#REPEAT(8)
  create_terrain DIRT3 {
    base_terrain DIRT2
    land_percent 100
    number_of_clumps 8192
    spacing_to_specific_terrain LEAVES 1
  }
#END_REPEAT

#REPEAT(8)
  create_terrain SNOWSTRONG {
    base_terrain LEAVES
    land_percent 100
    number_of_clumps 8192
    terrain_mask 1
  }
#END_REPEAT

/* Wood and Stone Base */
#REPEAT(8)
  create_terrain SNOW_FOREST {
    base_terrain DIRT2
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* Forests in Base 2. */
#REPEAT(16)
  /* Highlights exactly one of the lands. */
  create_terrain DLC_BLACK {
    base_terrain DIRT3
    land_percent 100
  }

  create_terrain DLC_FORESTSNOWAUTUMN {
    base_terrain DLC_BLACK
    number_of_tiles 170
    number_of_clumps 369
  }

  #REPEAT(8)
    create_terrain DLC_DIRT4 {
      base_terrain DLC_BLACK
      land_percent 100
      number_of_clumps 8192
    }
  #END_REPEAT
#END_REPEAT

/* Covers the placeholder dirt. */
#REPEAT(8)
  create_terrain DIRT3 {
    base_terrain DLC_DIRT4
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

/* welcometorapture note: rework land generation in TG for forest mixing */
if 2_PLAYER_GAME
  create_terrain DLC_FORESTAUTUMN {
    base_terrain DLC_FORESTSNOWAUTUMN
    land_percent 1
    set_scale_by_size
    number_of_clumps 50
	}
endif

/* Middle hill masking. */
#REPEAT(8)
  create_terrain DLC_DRYGRASS {
    base_terrain SNOW
    land_percent 100
    number_of_clumps 8192
    spacing_to_other_terrain_types 2
  }
#END_REPEAT

#REPEAT(8)
  create_terrain GRASS {
    base_terrain SNOW
    land_percent 100
    number_of_clumps 8192
    terrain_mask 1
  }
#END_REPEAT

#REPEAT(8)
  create_terrain SNOW {
    base_terrain DLC_DRYGRASS
    land_percent 100
    number_of_clumps 8192
  }
#END_REPEAT

create_terrain LEAVES {
	base_terrain SNOW
	land_percent 3
	number_of_clumps 10
	set_scale_by_groups
	terrain_mask 1
	spacing_to_other_terrain_types 1
}

#REPEAT(8)
  create_terrain SNOWSTRONG {
    base_terrain SNOW
    land_percent 100
    number_of_clumps 8192
    height_limits 3 4
  }
#END_REPEAT

create_terrain GRAVEL {
	base_terrain SNOWSTRONG
	land_percent 1
	number_of_clumps 7
	terrain_mask 1
	height_limits 3 4
}

/* Middle Forests */
create_terrain DLC_FORESTSNOWAUTUMN {
	base_terrain SNOWSTRONG
	number_of_tiles 20
	number_of_clumps 3
	height_limits 3 4
}

create_terrain DLC_FORESTSNOWAUTUMN {
	base_terrain SNOW
	land_percent 1
	set_scale_by_size
	if 2_PLAYER_GAME
  	number_of_clumps 8
	else
  	number_of_clumps 15
	endif
	spacing_to_other_terrain_types 1
}

create_terrain SNOW_FOREST {
	base_terrain SNOW
	land_percent 1
	set_scale_by_size
	if 2_PLAYER_GAME
  	number_of_clumps 7
	else
  	number_of_clumps 15
	endif
	spacing_to_other_terrain_types 2
}

/* Masking the dirt the stone is on to look wintery. */
create_terrain SNOW_ROAD {
	base_terrain DIRT3
	land_percent 3
	set_scale_by_size
	number_of_clumps 75
	terrain_mask 1
}

/* Player land masking. */
create_terrain MUD {
	base_terrain GRASS2
	land_percent 3
	set_scale_by_size
	number_of_clumps 15
}

create_terrain SNOW_SOFT {
	base_terrain GRASS2
	land_percent 1
	set_scale_by_size
	number_of_clumps 15
}

#REPEAT(8)
  create_terrain GRASS_FLOWERS_2 {
    base_terrain SNOW_SOFT
    land_percent 100
    number_of_clumps 8192
    terrain_mask 1
  }
  create_terrain GRASS_FLOWERS_1 {
    base_terrain MUD
    land_percent 100
    number_of_clumps 8192
    terrain_mask 1
  }
#END_REPEAT

/* Outer sparse forest. */
create_terrain SNOW_FOREST {
	base_terrain GRASS
	land_percent 3
	set_scale_by_size
	number_of_clumps 85
	set_avoid_player_start_areas 20
}

<CONNECTION_GENERATION>
if 2_PLAYER_GAME
  create_connect_teams_lands {
    default_terrain_replacement SNOW_ROAD
    replace_terrain FOREST FOREST
    replace_terrain SNOW_FOREST SNOW_FOREST
    replace_terrain DIRT DIRT
    replace_terrain ICE ICENAV
    replace_terrain DLC_ROCK DLC_ROCK
    replace_terrain ICYSHORE ICYSHORE
    terrain_size GRASS2 2 1
    terrain_size DIRT 5 1
    terrain_size DIRT2 5 1
    terrain_size DLC_FORESTSNOWAUTUMN 4 1
    terrain_size DLC_FORESTAUTUMN 4 1
    terrain_cost FOREST 15
    terrain_cost SNOW 15
    terrain_cost GRASS_SNOW 7
  }
else
  create_connect_land_zones -9 -9 {
    replace_terrain DLC_FORESTSNOWAUTUMN SNOW_ROAD
    /* default_terrain_replacement SNOW_ROAD */
    replace_terrain FOREST FOREST
    replace_terrain GRASS2 GRASS2
    replace_terrain GRASS_FLOWERS_1 GRASS_FLOWERS_1
    replace_terrain LEAVES LEAVES
    replace_terrain GRASS GRASS
    replace_terrain SNOW_FOREST SNOW_FOREST
    replace_terrain DIRT DIRT
    replace_terrain ICE ICENAV
    replace_terrain DLC_ROCK DLC_ROCK
    replace_terrain ICYSHORE ICYSHORE
    terrain_size GRASS2 2 1
    terrain_size DIRT 5 1
    terrain_size DIRT2 5 1
    terrain_size DLC_FORESTSNOWAUTUMN 2 1
    terrain_size DLC_FORESTAUTUMN 2 1
    terrain_cost FOREST 15
    terrain_cost SNOW 15
    terrain_cost GRASS_SNOW 7
    terrain_cost LEAVES 30
  }

  create_connect_land_zones -8 -8 {
    replace_terrain DLC_FORESTSNOWAUTUMN SNOW_ROAD
    /* default_terrain_replacement SNOW_ROAD */
    replace_terrain FOREST FOREST
    replace_terrain GRASS2 GRASS2
    replace_terrain GRASS_FLOWERS_1 GRASS_FLOWERS_1
    replace_terrain LEAVES LEAVES
    replace_terrain GRASS GRASS
    replace_terrain SNOW_FOREST SNOW_FOREST
    replace_terrain DIRT DIRT
    replace_terrain ICE ICENAV
    replace_terrain DLC_ROCK DLC_ROCK
    replace_terrain ICYSHORE ICYSHORE
    terrain_size GRASS2 2 1
    terrain_size DIRT 5 1
    terrain_size DIRT2 5 1
    terrain_size DLC_FORESTSNOWAUTUMN 2 1
    terrain_size DLC_FORESTAUTUMN 2 1
    terrain_cost FOREST 15
    terrain_cost SNOW 15
    terrain_cost GRASS_SNOW 7
    terrain_cost LEAVES 30
  }

  create_connect_land_zones -7 -7 {
    replace_terrain DLC_FORESTSNOWAUTUMN SNOW_ROAD
    /* default_terrain_replacement SNOW_ROAD */
    replace_terrain FOREST FOREST
    replace_terrain GRASS2 GRASS2
    replace_terrain GRASS_FLOWERS_1 GRASS_FLOWERS_1
    replace_terrain LEAVES LEAVES
    replace_terrain GRASS GRASS
    replace_terrain SNOW_FOREST SNOW_FOREST
    replace_terrain DIRT DIRT
    replace_terrain ICE ICENAV
    replace_terrain DLC_ROCK DLC_ROCK
    replace_terrain ICYSHORE ICYSHORE
    terrain_size GRASS2 2 1
    terrain_size DIRT 5 1
    terrain_size DIRT2 5 1
    terrain_size DLC_FORESTSNOWAUTUMN 2 1
    terrain_size DLC_FORESTAUTUMN 2 1
    terrain_cost FOREST 15
    terrain_cost SNOW 15
    terrain_cost GRASS_SNOW 7
    terrain_cost LEAVES 30
  }

  create_connect_land_zones -6 -6 {
    replace_terrain DLC_FORESTSNOWAUTUMN SNOW_ROAD
    /* default_terrain_replacement SNOW_ROAD */
    replace_terrain FOREST FOREST
    replace_terrain GRASS2 GRASS2
    replace_terrain GRASS_FLOWERS_1 GRASS_FLOWERS_1
    replace_terrain LEAVES LEAVES
    replace_terrain GRASS GRASS
    replace_terrain SNOW_FOREST SNOW_FOREST
    replace_terrain DIRT DIRT
    replace_terrain ICE ICENAV
    replace_terrain DLC_ROCK DLC_ROCK
    replace_terrain ICYSHORE ICYSHORE
    terrain_size GRASS2 2 1
    terrain_size DIRT 5 1
    terrain_size DIRT2 5 1
