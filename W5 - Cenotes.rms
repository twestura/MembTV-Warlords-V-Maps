	create_player_lands
	{
		if DEBUG_MODE
			terrain_type SNOW
		elseif CONFINED_SETUP
			terrain_type BASE_TERRAIN
		else
			terrain_type SPAWN_PLACEHOLDER
		endif

		if CONFINED_SETUP
			number_of_tiles 0
			base_size 0
		else
			number_of_tiles 1500
			base_size 14
		endif

		clumping_factor 15
		other_zone_avoidance_distance 2
		base_elevation 4

		if MAPSIZE_MINI
			circle_radius 33 0
		elseif MAPSIZE_TINY
			if 2_PLAYER_GAME
				circle_radius rnd(32,36) 4
			else
				circle_radius 34 1
			endif
		elseif MAPSIZE_SMALL
			circle_radius 34 1
		elseif MAPSIZE_MEDIUM
			circle_radius 35 2
		elseif MAPSIZE_NORMAL
			circle_radius 36 3
		elseif MAPSIZE_LARGE
			circle_radius 37 4
		elseif MAPSIZE_HUGE
			circle_radius 38 5
		elseif MAPSIZE_GIANT
			circle_radius 39 6
		elseif MAPSIZE_MASSIVE
			circle_radius 39 6
		elseif MAPSIZE_ENORMOUS
			circle_radius 39 6
		elseif MAPSIZE_COLOSSAL
			circle_radius 39 6
		elseif MAPSIZE_INCREDIBLE
			circle_radius 39 6
		elseif MAPSIZE_MONSTROUS
			circle_radius 39 6
		elseif MAPSIZE_LUDICROUS
			circle_radius 39 6
		endif
	}

<ELEVATION_GENERATION>
	create_elevation 4
	{
		enable_balanced_elevation
		base_terrain BASE_TERRAIN

		number_of_tiles 99999999
		number_of_clumps 1024
	}
	create_elevation 6
	{
		enable_balanced_elevation
		base_terrain BASE_TERRAIN

		number_of_tiles (2048 * MAPSCALE_AREA)
		number_of_clumps (32 * MAPSCALE_AREA)
	}

<CLIFF_GENERATION>
	#define CLIFF_ENABLE

	#include_drs includes/cliffs.inc
	cliff_type CLIFF_TYPE

<TERRAIN_GENERATION>
	#include_drs includes/colour.inc
	color_correction COLOUR_MOOD



	create_terrain WATER_SHALLOW { base_terrain BEACH_TERRAIN land_percent 100 number_of_clumps 512 set_scale_by_groups spacing_to_other_terrain_types 1 beach_terrain BEACH_TERRAIN }
	create_terrain WATER_SHALLOW { base_terrain BEACH_TERRAIN land_percent 100 number_of_clumps 512 set_scale_by_groups spacing_to_other_terrain_types 1 beach_terrain BEACH_TERRAIN }
	create_terrain WATER_SHALLOW { base_terrain BEACH_TERRAIN land_percent 100 number_of_clumps 512 set_scale_by_groups spacing_to_other_terrain_types 1 beach_terrain BEACH_TERRAIN }
	create_terrain WATER_SHALLOW { base_terrain BEACH_TERRAIN land_percent 100 number_of_clumps 512 set_scale_by_groups spacing_to_other_terrain_types 1 beach_terrain BEACH_TERRAIN }

	create_terrain CENOTE_TERRAIN
	{
		base_terrain BASE_TERRAIN
		land_percent 100
		number_of_clumps 512
		set_scale_by_groups
		height_limits 0 1
		beach_terrain BEACH_TERRAIN
	}

	create_terrain CENOTE_TERRAIN
	{
		base_terrain BASE_TERRAIN
		land_percent 100
		number_of_clumps 512
		set_scale_by_groups
		height_limits 2 2
		terrain_mask 2
	}

	create_terrain CENOTE_BLEND
	{
		base_terrain CENOTE_TERRAIN
		land_percent 100
		number_of_clumps 512
		set_scale_by_groups
		height_limits 0 0
		terrain_mask 1
		beach_terrain BEACH_TERRAIN
	}

	create_terrain SHALLOWS
	{
		base_terrain WATER_SHALLOW
		land_percent 1
		number_of_clumps 64
		set_scale_by_groups
	}

	create_terrain WATER_SHALLOW
	{
		base_terrain SHALLOWS
		number_of_tiles 48
		number_of_clumps 32
		set_scale_by_size
		set_scale_by_groups
		terrain_mask 1
	}

	create_terrain BASE_FOREST_EDGE
	{
		base_terrain BASE_TERRAIN
		land_percent 8
		number_of_clumps 14
		set_scale_by_groups
		set_avoid_player_start_areas
		spacing_to_other_terrain_types 4
	}

	#const PLAYER_FOREST_TILES 180
	#const PLAYER_FOREST_CLUMPS 4
	#const PLAYER_FOREST_AVOIDANCE 6
	#const PLAYER_FOREST_AVOIDANCE_EXTERNAL 0
	#const PLAYER_FOREST_MIN_HEIGHT 0
	#const PLAYER_FOREST_MAX_HEIGHT 7
	#const PLAYER_FOREST_SPAWN_AVOIDANCE 0
	#const PLAYER_FOREST_TEAM_DEDUCTION 0.72
	#const PLAYER_FOREST_POND_TILES 8
	#const PLAYER_FOREST_POND_CLUMPS 1

	#include_drs includes/forest.inc

	create_terrain BASE_FOREST
	{
		base_terrain BASE_FOREST_EDGE
		land_percent 100
		number_of_clumps 512
		set_scale_by_groups
		spacing_to_other_terrain_types 1
	}

	create_terrain BASE_FOREST_VARIATION
	{
		base_terrain BASE_FOREST
		number_of_tiles 120
		number_of_clumps 60
		set_scale_by_size
		set_scale_by_groups
	}

	create_terrain BASE_FOREST
	{
		base_terrain BASE_FOREST_EDGE
		number_of_tiles 300
		number_of_clumps 200
		set_scale_by_size
		set_scale_by_groups
	}

	create_terrain STRAGGLER_FOREST
	{
		base_terrain BASE_TERRAIN
		land_percent 2
		number_of_clumps 14
		set_scale_by_groups
		set_avoid_player_start_areas
		spacing_to_other_terrain_types 3
	}

