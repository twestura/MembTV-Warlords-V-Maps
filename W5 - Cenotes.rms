<OBJECTS_GENERATION>
	if TERRAIN_DEBUGGING
	else
		#define PRELIMINARIES
		if PRELIMINARIES
			#const RESOURCE_SPACING_DEFAULT 12
			#const RESOURCE_SPACING_FAR 20
			#const RESOURCE_RESTRICTION 2

			#include_drs includes/object_setup.inc
			#include_drs includes/market_objects.inc

			create_object PLACEHOLDER_GENERIC /* Outside Area */
			{
				number_of_objects 4096
				set_scaling_to_map_size
				temp_min_distance_group_placement 1
				terrain_to_place_on CENOTE_TERRAIN

				actor_area 7000
				actor_area_radius 4
			}
		endif

		#include_drs includes/town_centres.inc
		#include_drs includes/villagers.inc
		#include_drs includes/scouts.inc
		#include_drs includes/walls.inc

		#include_drs includes/defend_wonder.inc
		#include_drs includes/regicide.inc
		#include_drs includes/capture_relic.inc

		if NOMAD_START
		else
			#include_drs includes/stragglers.inc

			#define FORAGE_BUSH_PRIMARY
			#define GOLD_PRIMARY
			#define GOLD_SECONDARY
			#define GOLD_TERTIARY
			#define STONE_PRIMARY
			#define STONE_SECONDARY
			#define FORAGE_BUSH_ADDITIONAL
			#define GOLD_ADDITIONAL
			#define STONE_ADDITIONAL

			#include_drs includes/starting_resources.inc

			if DEATH_MATCH
			elseif INFINITE_RESOURCES
			else
				#define HERDABLE_STARTING_COUNT_FOUR

				#include_drs includes/herdable_starting.inc
				#include_drs includes/herdable.inc

				start_random
					percent_chance 50 #define GAME_HUNTABLE
					percent_chance 50 #define GAME_CHICKEN
				end_random

				if GAME_HUNTABLE
					start_random
						percent_chance 80
							#const HUNTABLE_COUNT 3
						percent_chance 20
							#const HUNTABLE_COUNT 4
					end_random

					#const HUNTABLE_GROUPS 1
				endif

				if GAME_CHICKEN
					start_random
						percent_chance 20
							#const HUNTABLE_SMALL_COUNT 6
						percent_chance 40
							#const HUNTABLE_SMALL_COUNT 7
						percent_chance 40
							#const HUNTABLE_SMALL_COUNT 8
					end_random

					#const HUNTABLE_SMALL_GROUPS 1
				endif

				#include_drs includes/huntable.inc
				#include_drs includes/lureable.inc
